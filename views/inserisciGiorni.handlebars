<div class="container mt-4">
    <h2>Pianificazione Giornaliera</h2>
    <p class="text-muted">Associa un elemento a una data specifica.</p>
    <hr>

    <div class="card bg-light mb-4">
        <div class="card-body">
            <form id="formGiorno" class="row g-3 align-items-end">
                
                <div class="col-md-3">
                    <label class="form-label">Mese</label>
                    <select id="selectMese" class="form-select" required>
                        <option value="1">Gennaio</option>
                        <option value="2">Febbraio</option>
                        <option value="3">Marzo</option>
                        <option value="4">Aprile</option>
                        <option value="5">Maggio</option>
                        <option value="6">Giugno</option>
                        <option value="7">Luglio</option>
                        <option value="8">Agosto</option>
                        <option value="9">Settembre</option>
                        <option value="10">Ottobre</option>
                        <option value="11">Novembre</option>
                        <option value="12">Dicembre</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Giorno</label>
                    <input type="number" id="inputGiorno" class="form-control" min="1" max="31" value="1" required>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Cosa succede in questo giorno?</label>
                    <select id="selectElemento" class="form-select" required>
                        <option value="" disabled selected>Scegli un elemento...</option>
                        {{#each elementi}}
                            <option value="{{this._id}}">{{this.icona}} {{this.name}}</option>
                        {{/each}}
                    </select>
                </div>

                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-calendar-check"></i> Salva nel Piano
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Giorni già pianificati</div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Data</th>
                        <th>Elementi Associati</th>
                    </tr>
                </thead>
                <tbody id="tabellaGiorniCorpo">
                    {{#each giorni}}
                    <tr>
                        <td class="cella-data" style="font-size: 1.2rem;" data-raw="{{this.giorno}}">{{this.giorno}}</td>
                        <td>
                            {{#each this.elementi}}
                                <span class="badge rounded-pill" style="font-size: 1.3rem; color: white; background-color: {{this.colore}}; padding: 8px 12px; margin-right: 5px;">
                                    {{this.icona}} {{this.name}}
                                </span>
                            {{/each}}
                        </td>
						<td class="text-end">
							<button class="btn btn-sm btn-outline-danger" onclick="eliminaGiorno('{{this._id}}')">
								Elimina Giorno
							</button>
						</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // Configurazione nomi mesi per la visualizzazione
    const nomiMesi = ["Gennaio", "Febbraio", "Marzo", "Aprile", "Maggio", "Giugno", "Luglio", "Agosto", "Settembre", "Ottobre", "Novembre", "Dicembre"];

    // 1. Funzione per formattare il numero MMDD in testo leggibile
    function formattaDataLeggibile(numero) {
        const s = numero.toString();
        const meseNum = s.length === 3 ? s.substring(0, 1) : s.substring(0, 2);
        const giornoNum = s.length === 3 ? s.substring(1) : s.substring(2);
        return `${giornoNum} ${nomiMesi[parseInt(meseNum) - 1]}`;
    }

    // 2. Funzione per aggiornare la tabella dopo il salvataggio
    function renderizzaTabellaGiorni(lista) {
        const corpo = document.getElementById('tabellaGiorniCorpo');
        corpo.innerHTML = lista.map(g => `
            <tr>
                <td><strong>${formattaDataLeggibile(g.giorno)}</strong></td>
                <td>
                    ${g.elementi.map(el => `
                        <span class="badge rounded-pill" style="font-size: 1.3rem; color: white; background-color: ${el.colore}; padding: 8px 12px; margin-right: 5px;">
                            ${el.icona} ${el.name}
                        </span>
                    `).join('')}
                </td>
				<td class="text-end">
					<button class="btn btn-sm btn-outline-danger" onclick="eliminaGiorno('${g._id}')">
						Elimina Giorno
					</button>
				</td>
            </tr>
        `).join('');
    }

    // 3. Esegui la formattazione iniziale delle date già presenti al caricamento
    document.querySelectorAll('.cella-data').forEach(td => {
        const raw = td.getAttribute('data-raw');
        td.innerHTML = `<strong>${formattaDataLeggibile(raw)}</strong>`;
    });

	async function eliminaGiorno(id) {
		if (!confirm("Vuoi davvero eliminare l'intera giornata?")) return;

		try {
		
			const ingrData = {
				identificatore: id
			};
			const fetchConfigData = {
				method: "POST",
				body: JSON.stringify(ingrData),
				headers: {
					"Content-Type": "application/json"
				}
			};
		
            const response = await fetch('/DELETEgiorno', fetchConfigData);
			
			if (response.ok) {
				console.log("OOOOK eliminato");
				const nuoviGiorni = await response.json();
				if (nuoviGiorni !== "none") {
					renderizzaTabellaGiorni(nuoviGiorni);
				}
			}
		} catch (err) {
			alert("Errore nell'eliminazione del giorno");
		}
	}


    // 4. Gestione Invio Form
    document.getElementById('formGiorno').addEventListener('submit', async (e) => {
        e.preventDefault();

        const mese = document.getElementById('selectMese').value;
        const giorno = document.getElementById('inputGiorno').value;
        const elementoId = document.getElementById('selectElemento').value;

        // Trasformazione in formato MMDD (es: 5 e 22 -> 522)
        // La formula (mese * 100) + giorno è la più sicura
        const dataFormattata = (parseInt(mese) * 100) + parseInt(giorno);

		console.log("INVIO: "+dataFormattata+" e "+elementoId);

        try {
		
			const ingrData = {
				data: dataFormattata,
				identificatoreElemento: elementoId
			};
			const fetchConfigData = {
				method: "POST",
				body: JSON.stringify(ingrData),
				headers: {
					"Content-Type": "application/json"
				}
			};
		
            const response = await fetch('/NEWgiorno', fetchConfigData);
			
			if (response.ok) {
				console.log("OOOOK");
				const allGio = await response.json();

				if (allGio !== "none") {
					// Aggiorna la tabella
					renderizzaTabellaGiorni(allGio);
					
					// RESET: Elemento torna vuoto, Mese e Giorno restano come sono
					document.getElementById('selectElemento').selectedIndex = 0;
					
					// Feedback visivo opzionale
					console.log("Salvato con successo come:", dataFormattata);
				}
			}
        } catch (err) {
            alert("Errore durante il salvataggio del giorno: "+err);
        }
    });
</script>