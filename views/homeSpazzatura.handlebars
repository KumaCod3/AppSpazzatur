<div class="container-custom">
    <div class="header flex-wrap">
        <div class="actions">
            <a href="/paginaGiorni" class="btn-custom-neon">Inserisci Giorni</a>
            <a href="/paginaElementi" class="btn-custom-outline">Tipi Immondizia</a>
        </div>
    </div>

<div id="oggi-container" class="card-glass mb-5">
    <div class="card-body text-center" style="padding: 60px 20px;">
        <h2 class="text-accent" style="font-weight: 700; margin-bottom: 40px; letter-spacing: 2px; text-transform: uppercase;">
            Cosa buttiamo oggi?
        </h2>
        
        {{#if oggiInfo}}
            <div class="d-flex justify-content-center flex-wrap" style="gap: 50px;"> 
                {{#each oggiInfo.elementi}}
                    <div class="element-box" style="display: flex; flex-direction: column; align-items: center;">
                        <div style="font-size: 5rem; line-height: 1; margin-bottom: 15px; filter: drop-shadow(0 0 10px {{this.colore}});">
                            {{this.icona}}
                        </div>
                        <div style="font-size: 1.5rem; font-weight: 800; color: {{this.colore}}; text-transform: uppercase; letter-spacing: 2px;">
                            {{this.name}}
                        </div>
                    </div>
                {{/each}}
            </div>
        {{else}}
            <div class="py-5">
                <span style="font-size: 5rem; display: block; margin-bottom: 20px;">🎉</span>
                <h3 class="display-5" style="color: #00ff88; font-weight: bold;">OGGI VACANZA!</h3>
                <p style="color: #8892b0;" class="fs-5">Nessun ritiro previsto per oggi.</p>
            </div>
        {{/if}}
    </div>
</div>

    <div class="px-2"> 
        <h4 class="text-accent mb-4" style="letter-spacing: 1.5px;">IL CALENDARIO COMPLETO</h4>
    </div>

    <div class="card-glass shadow-sm" style="overflow: hidden; border-radius: 20px;">
        <table class="table-dark-custom table mb-0">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Cosa esporre</th>
                    <th style="text-align: center;">ID (DB)</th>
                </tr>
            </thead>
            <tbody>
                {{#each giorni}}
                <tr>
                    <td class="data-leggibile" data-value="{{this.giorno}}" style="font-weight: bold; color: white;">
                        </td>
                    <td>
                        {{#each this.elementi}}
                            <span style="color: {{this.colore}}; font-size: 1.1rem; margin-right: 15px; display: inline-block;">
                                {{this.icona}} <strong>{{this.name}}</strong>
                            </span>
                        {{/each}}
                    </td>
                    <td style="text-align: center; opacity: 0.5; font-family: monospace;">
                        {{this.giorno}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>

<script>
	document.addEventListener("DOMContentLoaded", function() {
		const mesi = [
		  "Gennaio", "Febbraio", "Marzo", "Aprile", "Maggio", "Giugno",
		  "Luglio", "Agosto", "Settembre", "Ottobre", "Novembre", "Dicembre"
		];

		const celleData = document.querySelectorAll('.data-leggibile');
		
		celleData.forEach(cella => {
		  const valore = cella.getAttribute('data-value');
		  if (valore) {
			const s = valore.toString();
			const meseNum = s.length === 3 ? s.substring(0, 1) : s.substring(0, 2);
			const giornoNum = s.length === 3 ? s.substring(1) : s.substring(2);
			const nomeMese = mesi[parseInt(meseNum) - 1];
			
			cella.innerHTML = `${giornoNum} <span style="font-weight: 500; font-size: 1.0em;">${nomeMese}</span>`;
		  }
		});
	});
    
</script>